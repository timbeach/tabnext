{
  "manifest_version": 3,
  "name": "tabnext",
  "version": "1.0.0",
  "description": "Open new tabs next to the current tab, and count how many tabs you have open.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "tabnext — open tab count",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
